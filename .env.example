APP_NAME=AI Video Dubbing Backend
DEBUG=false
ALLOWED_ORIGINS=*
MAX_UPLOAD_MB=1024
WORKER_COUNT=1
JOB_RETENTION_DAYS=7

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
AUDIO_SAMPLE_RATE=16000
MAX_VIDEO_DURATION_SECONDS=1200

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=3
WHISPER_VAD_FILTER=true

TRANSLATION_MODEL=Helsinki-NLP/opus-mt-en-hi
TRANSLATION_BATCH_SIZE=4
TRANSLATION_MAX_INPUT_TOKENS=384

TTS_MODEL=facebook/mms-tts-hin
TTS_DEVICE=cpu
TTS_NOISE_SCALE=0.667
TTS_NOISE_SCALE_DURATION=0.8
MAX_TTS_SPEEDUP=1.30

KEEP_WORK_FILES=false
OFFLINE_MODE=false